# Supabase Keys (Public & Private)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Express Backend for Google Classroom Integration
NEXT_PUBLIC_ERP_BACKEND_URL=http://localhost:5000
ERP_BACKEND_URL=http://localhost:5000
ERP_BACKEND_JWT_SECRET=your_backend_jwt_secret_here

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_standard_password
